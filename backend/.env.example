# 后端监听端口
HOST=0.0.0.0
PORT=3001

# 百数云 OpenAPI 根路径（不要带末尾斜杠）
BES_BASE_URL=https://ahyg.online-office.net/openapi/v1

# 默认 app / entry（前端也可带自己的 appId/entryId）
BES_APP_ID=59b376f42fee5822c6ac906a
BES_ENTRY_ID=38104b6c9d74ce86a7c395b6

# API Key（建议只放后端，不放前端）
BES_API_KEY=your_baishuyun_api_key

# 允许跨域来源，多个用逗号分隔，* 表示全放行
CORS_ORIGIN=*

# 是否打印代理调试日志（1 开启，0 关闭）
DEBUG_PROXY=0

# 前端静态页面根目录（partner-entry-training 等页面所在目录）
FRONTEND_ROOT=/opt/inspection

# 点检任务存储模式：
# bes  = 继续使用百数云点检任务底表
# dual = 生成/更新任务时百数云与 MySQL 双写，读取仍走百数云（建议先用这个观察）
# db   = 点检任务读取/生成/更新全部走 MySQL
TASK_STORE_MODE=bes

# MySQL 8.x 连接信息（本地库/服务器库只需改这里，不要写死到代码）
DB_CLIENT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=inspection
DB_USER=root
DB_PASSWORD=
DB_POOL_MAX=10
TASK_DB_TABLE=inspection_task_base
